# SwarmAlpha Environment Variables

# DeepSeek API Key (required for orchestrator)
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# OpenAI API Key (optional, for providers.ts)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (optional, for providers.ts)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Zhipu (GLM) API Key (optional, for providers.ts / 跨模型验证)
# 获取地址：https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-api-key-here

# Qwen (DashScope) API Key (optional, for providers.ts / 跨模型验证)
# 获取地址：https://dashscope.console.aliyun.com/
QWEN_API_KEY=your-qwen-api-key-here

# Local LLM URL (optional, for Ollama)
LOCAL_LLM_URL=http://localhost:11434

# ==================== 新闻感知模块 API Keys ====================

# Tavily API Key (推荐，专业新闻搜索)
# 获取地址：https://tavily.com/
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# Jina AI Reader API Key (可选，网页内容提取)
# 获取地址：https://jina.ai/reader/
JINA_API_KEY=jina-your-jina-api-key-here

# 自定义新闻 API URL (可选)
CUSTOM_NEWS_API_URL=https://your-custom-api.com/news
CUSTOM_NEWS_API_KEY=your-custom-api-key-here